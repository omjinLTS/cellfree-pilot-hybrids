# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments and local env files
.venv/
venv/
env/
.env
.env.*

# Local editor / assistant state
.vscode/
.claude/

# Experiment logs and stale process markers
logs/*.log
logs/*.pid
logs/*.pids
logs/*.done

# Large local archive generated during cleanup
.artifact_archive/

# Smoke / sandbox figures (use specific suffixes for final results)
figures/*_smoke*
MJH/_smoke*/

# Per-UE raw CSVs are too large for git; keep setup-level / summary CSVs only
figures/sweep_taup_raw_*.csv

# Paper PDFs are local references, not repository assets
*.pdf

# LaTeX compile artifacts
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.nav
*.out
*.run.xml
*.snm
*.synctex.gz
*.toc
*.vrb
*.xdv

# OS noise
.DS_Store
Thumbs.db
